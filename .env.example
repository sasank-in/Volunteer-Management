# Copy this file to .env and fill in real values. Do NOT commit .env.

# Database Configuration - shared across all services
DB_USER=your_db_user
DB_PASSWORD=change_me

# Database URLs
DB_URL=jdbc:postgresql://localhost:5432/volunteer_user_db
USER_DB_URL=jdbc:postgresql://localhost:5432/volunteer_user_db
EVENT_DB_URL=jdbc:postgresql://localhost:5432/volunteer_event_db
NOTIFICATION_DB_URL=jdbc:postgresql://localhost:5432/volunteer_notification_db

# JWT Configuration
# Generate with: openssl rand -base64 32
JWT_SECRET=replace_with_base64_32byte_secret
JWT_ISSUER=volunteer-user-service
JWT_EXPIRES_IN=3600

# Service Discovery
EUREKA_URL=http://localhost:8761/eureka

# Cache (event-service): in-memory (default) or redis
APP_CACHE_TYPE=in-memory
REDIS_HOST=localhost
REDIS_PORT=6379

# CORS - comma-separated list of allowed frontend origins
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Email (optional - notifications)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=app_password_here
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true
